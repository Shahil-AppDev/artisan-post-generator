NODE_ENV=development
PORT=5000

DATABASE_URL=postgresql://artisan_user:artisan_secure_password_2024@localhost:5432/artisan_posts

JWT_SECRET=your_jwt_secret_change_in_production_min_32_chars_long
JWT_EXPIRES_IN=7d

# AI Configuration
# Provider: 'deepseek' (recommandé, moins cher) ou 'openai'
AI_PROVIDER=deepseek
AI_API_KEY=sk-your-deepseek-or-openai-api-key-here
AI_MODEL=deepseek-chat

# Ancienne configuration OpenAI (toujours supportée)
# AI_PROVIDER=openai
# AI_API_KEY=sk-your-openai-api-key
# AI_MODEL=gpt-4

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/artisan-posts

CORS_ORIGIN=http://localhost:3000

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
